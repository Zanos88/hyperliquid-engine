# New, dedicated bot instance — must NOT reuse Bullphoric's TELEGRAM_BOT_TOKEN
# or TELEGRAM_CHAT_ID env vars.
BTC_SIGNAL_BOT_TELEGRAM_TOKEN=
BTC_SIGNAL_BOT_TELEGRAM_CHAT_ID=

# ── Propr API (Stage 2) ──────────────────────────────────────────────
# Set these as Railway service variables (or a local gitignored .env).
# Never commit real values.
# API key: app.propr.xyz -> Settings (format pk_live_...)
PROPR_API_KEY=
# Builder code: app.propr.xyz -> Settings -> Developer (format builder_...)
# Sent as X-Builder-Code on all requests to identify this bot as a
# legitimate integration. Optional but recommended.
PROPR_BUILDER_CODE=
# API base override (defaults to live https://api.propr.xyz/v1).
# Beta env: https://api.beta.propr.xyz/v1
PROPR_API_URL=
PROPR_WS_URL=

# ── Execution safety (Stage 2) ───────────────────────────────────────
# DRY_RUN defaults to true when unset. Going live requires BOTH
# DRY_RUN=false here AND feature_flags.execution_enabled: true in
# config.yaml — a deliberate two-switch action.
DRY_RUN=

# Telegram control-plane allowlist (Stage 2): comma-separated Telegram
# user IDs permitted to use commands/buttons.
BTC_SIGNAL_BOT_ADMIN_IDS=

# Postgres (Stage 2 telemetry) — any reachable Postgres; deployment-agnostic.
DATABASE_URL=

# Staging Supabase session-pooler URI for the DB test suite
# (tests/test_db_trigger.py). MUST be the staging project (btc-signal-bot-
# staging), NEVER live — the suite reads this var exclusively and refuses to
# run if it detects the live project ref. Leave blank in prod/Railway.
TEST_DATABASE_URL=
